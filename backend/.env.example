# AI-Setu CRM Backend - Environment Configuration
# Copy this file to .env and fill in the values

# Application
APP_ENV=development
APP_NAME=AI-Setu CRM
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
ENCRYPTION_KEY=change-this-to-a-32-byte-hex-key

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=ai_setu_crm

# JWT
JWT_SECRET=change-this-to-a-secure-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend URL (for invite links etc.)
FRONTEND_URL=http://localhost:5173

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# Resend Email (optional)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Anthropic AI (optional)
ANTHROPIC_API_KEY=
